{
    "compilerOptions": {
      "moduleResolution": "bundler",
      "module": "ESNext",
      "target": "ESNext",
      "jsx": "react-jsx",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "isolatedModules": true,
      "noEmit": true
    }
  }